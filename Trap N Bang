local dragging, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)


TextInput.Focused:Connect(function()
    TweenService:Create(InputStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(100, 60, 220)}):Play()
end)
TextInput.FocusLost:Connect(function()
    TweenService:Create(InputStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 60, 80)}):Play()
end)


local function setStatus(msg, color)
    StatusLabel.Text = msg
    StatusLabel.TextColor3 = color or Color3.fromRGB(150, 150, 170)
end


GetKeyBtn.MouseButton1Click:Connect(function()
    local link = Junkie.get_key_link()
    if link then
        setclipboard(link)
        setStatus("✅ Link copied! Complete the steps then paste your key.", Color3.fromRGB(100, 220, 120))
    else
        setStatus("⏳ Please wait 5 minutes before getting a new key.", Color3.fromRGB(220, 160, 60))
    end
end)


SubmitBtn.MouseButton1Click:Connect(function()
    local key = TextInput.Text
    if key == "" then
        setStatus("⚠️ Please enter a key.", Color3.fromRGB(220, 100, 100))
        return
    end

    SubmitBtn.Text = "Validating..."
    SubmitBtn.BackgroundColor3 = Color3.fromRGB(60, 40, 130)
    setStatus("🔄 Checking key...", Color3.fromRGB(150, 150, 200))

    task.spawn(function()
        local validation = Junkie.check_key(key)
        if validation and validation.valid then
            setStatus("✅ Key accepted! Loading...", Color3.fromRGB(100, 220, 120))
            SubmitBtn.Text = "✓ Success"
            SubmitBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 100)
            task.wait(1)

            
            BlurEffect:Destroy()
            ScreenGui:Destroy()

            
            getgenv().SCRIPT_KEY = key
            loadstring(game:HttpGet("https://api.jnkie.com/api/v1/luascripts/public/2ec16e1a6773f756b533331585ebf6b2ab783ed53f5aa358d80977fa4a851c4c/download"))()
        else
            setStatus("❌ " .. (validation and validation.error or "Invalid key."), Color3.fromRGB(220, 80, 80))
            SubmitBtn.Text = "Validate Key →"
            SubmitBtn.BackgroundColor3 = Color3.fromRGB(100, 60, 220)
        end
    end)
end)


